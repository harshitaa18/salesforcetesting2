<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Payment Data Processing</label>
    <description>PCI-DSS and GDPR Violation: Flow processes sensitive payment and PII data without encryption</description>
    
    <processType>AutoLaunchedFlow</processType>
    <apiVersion>60.0</apiVersion>
    
    <!-- PCI-DSS VIOLATION: Processing credit card data -->
    <variables>
        <name>creditCardNumber</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    
    <!-- GDPR VIOLATION: Processing PII -->
    <variables>
        <name>customerEmail</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    
    <variables>
        <name>socialSecurityNumber</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    
    <!-- SOC2 VIOLATION: No audit logging -->
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Process_Payment_Data</targetReference>
        </connector>
    </start>
    
    <!-- PCI-DSS VIOLATION: Unencrypted payment processing -->
    <actionCalls>
        <name>Process_Payment_Data</name>
        <label>Process Payment Data</label>
        <locationX>100</locationX>
        <locationY>100</locationY>
        <actionName>Account</actionName>
        <inputParameters>
            <name>name</name>
            <value>
                <stringValue>Payment Processing Account</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>description</name>
            <value>
                <stringValue>PCI-DSS_VIOLATION: Credit Card={!creditCardNumber}|GDPR_VIOLATION: Email={!customerEmail}|SSN={!socialSecurityNumber}</stringValue>
            </value>
        </inputParameters>
    </actionCalls>
    
    </Flow>
